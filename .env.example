# Copy to .env — never commit real secrets.
#
# Planning page (/planning): password gate + server-backed storage (Netlify Blobs on deploy).
#
# If the session secret contains & ? ^ * ! etc., wrap it in double quotes:
# NUXT_PLANNING_SESSION_SECRET="your-secret-here"

NUXT_PLANNING_PASSWORD=YourPlanningPasswordHere
NUXT_PLANNING_SESSION_SECRET="UseAtLeast32RandomCharsForSigningCookies"
